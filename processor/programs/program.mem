//real life progam 
/*
# -----------------------------
# STORE STUDENT DATA
# -----------------------------
addi x10, x0, 0        # base pointer
addi x11, x0, 1        # roll number
addi x12, x0, 40       # count

store_loop:

    # roll
    sw x11, 0(x10)

    # marks (example pattern)
    addi x13, x11, 40
    sw x13, 4(x10)

    # attendance (example pattern)
    addi x14, x11, 60
    sw x14, 8(x10)

    # next student
    addi x10, x10, 12
    addi x11, x11, 1
    addi x12, x12, -1

    bne x12, x0, store_loop


# -----------------------------
# FIND SELECTED STUDENT
# -----------------------------
addi x10, x0, 0        # pointer reset
addi x12, x0, 40       # count

find_loop:

    lw x15, 0(x10)     # roll
    lw x16, 4(x10)     # marks
    lw x17, 8(x10)     # attendance

    # check marks >= 50
    addi x18, x0, 60
    blt x16, x18, skip

    # check attendance >= 75
    addi x18, x0, 85
    blt x17, x18, skip

    # SELECTED → store in required registers
    add x1, x15, x0
    add x2, x16, x0
    add x3, x17, x0

    jal x0, end_program

skip:
    addi x10, x10, 12
    addi x12, x12, -1
    bne x12, x0, find_loop

end_program:
    nop
*/
